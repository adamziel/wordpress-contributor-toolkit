{
  "name": "electron-setup-wordpress-core",
  "version": "0.1.0",
  "private": true,
  "description": "Electron app to setup WordPress develop structure and run npm install",
  "main": "src/main.js",
  "scripts": {
    "start": "concurrently -k \"npm:build:watch\" \"electron .\"",
    "build:watch": "esbuild src/renderer/index.jsx --bundle --outdir=src/renderer --loader:.css=css --platform=browser --format=iife --jsx=automatic --log-level=info --watch",
    "build:once": "esbuild src/renderer/index.jsx --bundle --outdir=src/renderer --loader:.css=css --platform=browser --format=iife --jsx=automatic --log-level=info",
    "postinstall": "electron-builder install-app-deps",
    "dist:win": "electron-builder --win --publish never",
    "dist": "electron-builder --publish never"
  },
  "dependencies": {
    "@wp-playground/cli": "^2.0.13",
    "@wordpress/components": "^28.2.0",
    "@wordpress/icons": "^10.7.0",
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.13.0",
    "isomorphic-git": "^1.24.4",
    "diff": "^5.2.0",
    "electron-store": "^10.0.1",
    "extract-zip": "^2.0.1",
    "fs-extra": "^11.2.0",
    "npm": "^10.8.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.23.0",
    "concurrently": "^8.2.2"
  }
}
